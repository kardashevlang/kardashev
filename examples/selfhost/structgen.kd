// v94: infer the concrete tag bound to `T` for a generic call — the type of the
// first argument whose declared param type is `T` (-1) or `&T` (199). 0 = could
// not infer (no generic-typed param), which surfaces as a type error upstream.
fn infer_tcur(args: &Vec<Box<Expr>>, params: &Vec<Param>, env: &HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>) -> i64 ! { alloc } {
    let np = vec_len(params); let mut i = 0; let mut found = 0;
    while i < np {
        let pm = vec_get(params, i);
        if found == 0 {
            if pm.ty == 0 - 1 { let a = vec_get(args, i); found = type_of(&(*a), env, structs, fns); }
            else { if pm.ty == 199 { let a = vec_get(args, i); let t = type_of(&(*a), env, structs, fns); found = if t >= 200 { t - 200 } else { 0 }; }
            else { let z = 0; } }
        } else { let z = 0; }
        i = i + 1;
    }
    found
}
// v94: infer `T` for a generic struct literal — the type of the first field value
// whose declared field type is `T` (-1) or `&T` (199).
fn infer_struct_tcur(vals: &Vec<Box<Expr>>, fields: &Vec<Param>, env: &HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>) -> i64 ! { alloc } {
    let nf = vec_len(fields); let mut i = 0; let mut found = 0;
    while i < nf {
        let f = vec_get(fields, i);
        if found == 0 {
            if f.ty == 0 - 1 { let v = vec_get(vals, i); found = type_of(&(*v), env, structs, fns); }
            else { if f.ty == 199 { let v = vec_get(vals, i); let t = type_of(&(*v), env, structs, fns); found = if t >= 200 { t - 200 } else { 0 }; }
            else { let z = 0; } }
        } else { let z = 0; }
        i = i + 1;
    }
    found
}
// v94: build the specialized SDef for a generic struct at concrete tag `tcur` —
// mangled name, `gp=0`, every `T` field type substituted. Codegen/typecheck then
// treat it as an ordinary concrete struct (`Field`/`ty_llvm` read its fields).
fn specialize_struct(sd: &SDef, tcur: i64, structs: &Vec<SDef>) -> SDef ! { alloc } {
    let mn = mangle(&sd.name, tcur, structs);
    let nf = vec_len(&sd.fields);
    let mut nfields = vec_new();
    let mut i = 0;
    while i < nf {
        let f = vec_get(&sd.fields, i);
        vec_push(&mut nfields, Param { name: clone(&f.name), ty: subst_ty(f.ty, tcur) });
        i = i + 1;
    }
    SDef { name: mn, gp: 0, fields: nfields }
}
// Scan one expr for generic struct literals; for each, infer `T` and register its
// specialized instance into `structs` if not already present (dedup by mangled
// name). `env` is the using-fn's binding environment (param/let types).
fn mono_structs_expr(e: &Expr, env: &HashMap<String, i64>, structs: &mut Vec<SDef>, fns: &Vec<Fn>) ! { alloc } {
    match e {
        Num(_) => { let z = 0; },
        Var(_) => { let z = 0; },
        Bin(_, a, b) => { mono_structs_expr(&(**a), env, structs, fns); mono_structs_expr(&(**b), env, structs, fns); },
        If(c, t, e2) => { mono_structs_expr(&(**c), env, structs, fns); mono_structs_expr(&(**t), env, structs, fns); mono_structs_expr(&(**e2), env, structs, fns); },
        SLit(si, vals) => {
            // recurse into field values first (nested literals)
            let nv = vec_len(vals); let mut i = 0;
            while i < nv { let v = vec_get(vals, i); mono_structs_expr(&(*v), env, structs, fns); i = i + 1; }
            let sd = vec_get(structs, *si);
            if sd.gp == 1 {
                let tcur = infer_struct_tcur(vals, &sd.fields, env, structs, fns);
                if tcur != 0 {
                    let mn = mangle(&sd.name, tcur, structs);
                    if struct_index(structs, &mn) < 0 {
                        let inst = specialize_struct(&sd, tcur, structs);
                        vec_push(structs, inst);
                    } else { let z = 0; }
                } else { let z = 0; }
            } else { let z = 0; }
        },
        Field(obj, _) => { mono_structs_expr(&(**obj), env, structs, fns); },
        Ref(inner) => { mono_structs_expr(&(**inner), env, structs, fns); },
        Call(_, args) => { let na = vec_len(args); let mut i = 0; while i < na { let a = vec_get(args, i); mono_structs_expr(&(*a), env, structs, fns); i = i + 1; } },
        StrLit(_, _) => { let z = 0; },
        MethodCall(recv, _, args) => { mono_structs_expr(&(**recv), env, structs, fns); let na = vec_len(args); let mut i = 0; while i < na { let a = vec_get(args, i); mono_structs_expr(&(*a), env, structs, fns); i = i + 1; } },
        ECon(_, eargs) => { let na = vec_len(eargs); let mut i = 0; while i < na { let a = vec_get(eargs, i); mono_structs_expr(&(*a), env, structs, fns); i = i + 1; } },
        Match(scrut, _, jbody, nbody) => { mono_structs_expr(&(**scrut), env, structs, fns); mono_structs_expr(&(**jbody), env, structs, fns); mono_structs_expr(&(**nbody), env, structs, fns); },
    }
}
fn mono_structs_stmts(stmts: &Vec<Stmt>, env: &mut HashMap<String, i64>, structs: &mut Vec<SDef>, fns: &Vec<Fn>) ! { alloc } {
    let nl = vec_len(stmts); let mut k = 0;
    while k < nl {
        let s = vec_get(stmts, k);
        match s {
            Let(name, e) => { mono_structs_expr(&(*e), env, structs, fns); let t = type_of(&(*e), env, structs, fns); hashmap_insert(env, name, t); },
            LetMut(name, e) => { mono_structs_expr(&(*e), env, structs, fns); let t = type_of(&(*e), env, structs, fns); hashmap_insert(env, name, t); },
            Assign(_, e) => { mono_structs_expr(&(*e), env, structs, fns); },
            While(cond, body) => { mono_structs_expr(&(*cond), env, structs, fns); mono_structs_stmts(&body, env, structs, fns); },
            IfS(cond, then_b, else_b) => { mono_structs_expr(&(*cond), env, structs, fns); mono_structs_stmts(&then_b, env, structs, fns); mono_structs_stmts(&else_b, env, structs, fns); },
            Break => { let z = 0; },
            Continue => { let z = 0; },
            ExprStmt(e) => { mono_structs_expr(&(*e), env, structs, fns); },
        }
        k = k + 1;
    }
}
// Register every generic-struct instance used by NON-GENERIC fns. (Generic fns are
// skipped here — their bodies are monomorphized when each fn instance is emitted.)
fn mono_structs_all(fns: &Vec<Fn>, structs: &mut Vec<SDef>) ! { alloc } {
    let nf = vec_len(fns); let mut i = 0;
    while i < nf {
        let g = vec_get(fns, i);
        if g.gp == 0 {
            let mut env = hashmap_new();
            let np = vec_len(&g.params); let mut p = 0;
            while p < np { let pm = vec_get(&g.params, p); hashmap_insert(&mut env, clone(&pm.name), pm.ty); p = p + 1; }
            mono_structs_stmts(&g.body.lets, &mut env, structs, fns);
            mono_structs_expr(&(*g.body.result), &env, structs, fns);
        } else { let z = 0; }
        i = i + 1;
    }
}
// ---- v94 generic-fn instance collection (mirrors the host's emittedInstances_) ----
// Scan one expr for calls to a generic fn; for each, infer `T` and append a
// MonoReq (deduped by mangled name) to `reqs`. `env` is the using-fn's env.
fn mono_fns_expr(e: &Expr, env: &HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>, reqs: &mut Vec<MonoReq>) ! { alloc } {
    match e {
        Num(_) => { let z = 0; },
        Var(_) => { let z = 0; },
        Bin(_, a, b) => { mono_fns_expr(&(**a), env, structs, fns, reqs); mono_fns_expr(&(**b), env, structs, fns, reqs); },
        If(c, t, e2) => { mono_fns_expr(&(**c), env, structs, fns, reqs); mono_fns_expr(&(**t), env, structs, fns, reqs); mono_fns_expr(&(**e2), env, structs, fns, reqs); },
        SLit(_, vals) => { let nv = vec_len(vals); let mut i = 0; while i < nv { let v = vec_get(vals, i); mono_fns_expr(&(*v), env, structs, fns, reqs); i = i + 1; } },
        Field(obj, _) => { mono_fns_expr(&(**obj), env, structs, fns, reqs); },
        Ref(inner) => { mono_fns_expr(&(**inner), env, structs, fns, reqs); },
        Call(name, args) => {
            let na = vec_len(args); let mut i = 0;
            while i < na { let a = vec_get(args, i); mono_fns_expr(&(*a), env, structs, fns, reqs); i = i + 1; }
            let gi = fn_index(fns, name);
            if gi >= 0 {
                let g = vec_get(fns, gi);
                if g.gp == 1 {
                    let tcur = infer_tcur(args, &g.params, env, structs, fns);
                    if tcur != 0 {
                        let mn = mangle(name, tcur, structs);
                        let exists = mono_index(reqs, &mn);
                        if exists < 0 { vec_push(reqs, MonoReq { gi: gi, si: 0 - 1, tag: tcur, mname: mn }); } else { let z = 0; }
                    } else { let z = 0; }
                } else { let z = 0; }
            } else { let z = 0; }
        },
        StrLit(_, _) => { let z = 0; },
        MethodCall(recv, _, args) => {
            // impl methods are monomorphic (gp=0) so no generic instance to request;
            // still recurse into the receiver + args for any nested generic calls.
            mono_fns_expr(&(**recv), env, structs, fns, reqs);
            let na = vec_len(args); let mut i = 0;
            while i < na { let a = vec_get(args, i); mono_fns_expr(&(*a), env, structs, fns, reqs); i = i + 1; }
        },
        ECon(_, eargs) => { let na = vec_len(eargs); let mut i = 0; while i < na { let a = vec_get(eargs, i); mono_fns_expr(&(*a), env, structs, fns, reqs); i = i + 1; } },
        Match(scrut, _, jbody, nbody) => { mono_fns_expr(&(**scrut), env, structs, fns, reqs); mono_fns_expr(&(**jbody), env, structs, fns, reqs); mono_fns_expr(&(**nbody), env, structs, fns, reqs); },
    }
}
fn mono_fns_stmts(stmts: &Vec<Stmt>, env: &mut HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>, reqs: &mut Vec<MonoReq>) ! { alloc } {
    let nl = vec_len(stmts); let mut k = 0;
    while k < nl {
        let s = vec_get(stmts, k);
        match s {
            Let(name, e) => { mono_fns_expr(&(*e), env, structs, fns, reqs); let t = type_of(&(*e), env, structs, fns); hashmap_insert(env, name, t); },
            LetMut(name, e) => { mono_fns_expr(&(*e), env, structs, fns, reqs); let t = type_of(&(*e), env, structs, fns); hashmap_insert(env, name, t); },
            Assign(_, e) => { mono_fns_expr(&(*e), env, structs, fns, reqs); },
            While(cond, body) => { mono_fns_expr(&(*cond), env, structs, fns, reqs); mono_fns_stmts(&body, env, structs, fns, reqs); },
            IfS(cond, then_b, else_b) => { mono_fns_expr(&(*cond), env, structs, fns, reqs); mono_fns_stmts(&then_b, env, structs, fns, reqs); mono_fns_stmts(&else_b, env, structs, fns, reqs); },
            Break => { let z = 0; },
            Continue => { let z = 0; },
            ExprStmt(e) => { mono_fns_expr(&(*e), env, structs, fns, reqs); },
        }
        k = k + 1;
    }
}
// Collect every generic-fn instance requested by NON-GENERIC fns, deduped by
// mangled name. (Generic fns calling other generics — nested instantiation — is a
// documented v94 deferral; we scan only the concrete fns.)
fn mono_fns_all(fns: &Vec<Fn>, structs: &Vec<SDef>) -> Vec<MonoReq> ! { alloc } {
    let mut reqs = vec_new();
    let nf = vec_len(fns); let mut i = 0;
    while i < nf {
        let g = vec_get(fns, i);
        if g.gp == 0 {
            let mut env = hashmap_new();
            let np = vec_len(&g.params); let mut p = 0;
            while p < np { let pm = vec_get(&g.params, p); hashmap_insert(&mut env, clone(&pm.name), pm.ty); p = p + 1; }
            mono_fns_stmts(&g.body.lets, &mut env, structs, fns, &mut reqs);
            mono_fns_expr(&(*g.body.result), &env, structs, fns, &mut reqs);
        } else { let z = 0; }
        i = i + 1;
    }
    reqs
}

// Type-check a statement list. Returns 1 if anything is ill-typed. `loop_depth`
// counts enclosing loops (break/continue outside any loop is an error).
fn check_stmts(stmts: &Vec<Stmt>, env: &mut HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>, loop_depth: i64) -> i64 ! { alloc } {
    let nl = vec_len(stmts);
    let mut bad = 0;
    let mut k = 0;
    while k < nl {
        let s = vec_get(stmts, k);
        match s {
            Let(name, e) => { let t = type_of(&(*e), env, structs, fns); bad = if t == 0 { 1 } else { bad }; hashmap_insert(env, name, t); },
            LetMut(name, e) => { let t = type_of(&(*e), env, structs, fns); bad = if t == 0 { 1 } else { bad }; hashmap_insert(env, name, t); },
            Assign(name, e) => {
                let t = type_of(&(*e), env, structs, fns);
                // The local must already exist, and the assigned type must match it.
                let prev = match hashmap_get(env, clone(&name)) { Some(x) => x, None => 0 };
                bad = if t == 0 { 1 } else { if prev == 0 { 1 } else { if t != prev { 1 } else { bad } } };
            },
            While(cond, body) => {
                let tc = type_of(&(*cond), env, structs, fns);
                bad = if tc != 2 { 1 } else { bad };   // condition must be bool
                let bb = check_stmts(&body, env, structs, fns, loop_depth + 1);
                bad = if bb == 1 { 1 } else { bad };
            },
            IfS(cond, then_b, else_b) => {
                let tc = type_of(&(*cond), env, structs, fns);
                bad = if tc != 2 { 1 } else { bad };   // condition must be bool
                let bt = check_stmts(&then_b, env, structs, fns, loop_depth);
                let be = check_stmts(&else_b, env, structs, fns, loop_depth);
                bad = if bt == 1 { 1 } else { if be == 1 { 1 } else { bad } };
            },
            Break => { bad = if loop_depth == 0 { 1 } else { bad }; },
            Continue => { bad = if loop_depth == 0 { 1 } else { bad }; },
            ExprStmt(e) => { let t = type_of(&(*e), env, structs, fns); bad = if t == 0 { 1 } else { bad }; },
        }
        k = k + 1;
    }
    bad
}
fn check_fn(f: &Fn, structs: &Vec<SDef>, fns: &Vec<Fn>) -> i64 ! { alloc } {
    let mut env = hashmap_new();
    let np = vec_len(&f.params);
    let mut p = 0;
    while p < np { let pm = vec_get(&f.params, p); hashmap_insert(&mut env, clone(&pm.name), pm.ty); p = p + 1; }
    let bad = check_stmts(&f.body.lets, &mut env, structs, fns, 0);
    let rt = type_of(&(*f.body.result), &env, structs, fns);
    // Reject returning a reference (rt >= 200): a returned `&local` would dangle.
    // In this subset (no ref fields, no ref-of-ref, no stored refs) a borrow can
    // only flow downward into a call and die at end of statement, so this single
    // rule is sufficient for soundness — no NLL needed.
    if bad == 1 { 0 } else { if rt == 0 { 0 } else { if rt >= 200 { 0 } else { if rt == f.ret { 1 } else { 0 } } } }
}

// ---- LLVM-IR codegen with typed values ----
fn fresh(c: &mut Ctr) -> i64 { let r = c.n; c.n = c.n + 1; r }
fn reg(n: i64) -> String ! { alloc } { let p = "%v"; let s = int_to_string(n); str_concat(&p, &s) }
fn arg_name(i: i64) -> String ! { alloc } { let p = "%arg"; let s = int_to_string(i); str_concat(&p, &s) }
// A basic-block label name (no leading '%'), e.g. "loop.header.3".
fn label(stem: &String, n: i64) -> String ! { alloc } { let s = int_to_string(n); let m = str_concat(stem, &s); m }
// A label as a `br` operand reference (with leading '%'), e.g. "%loop.header.3".
fn label_ref(stem: &String, n: i64) -> String ! { alloc } { let p = "%"; let l = label(stem, n); str_concat(&p, &l) }
fn app(buf: &mut String, s: String) ! { alloc } { string_push_str(buf, s); }
// The LLVM type string for a type tag: i64/bool -> "i64", String (tag 3) ->
// "{ ptr, i64, i64 }" (the host's {data,len,cap}), struct -> "{ i64, ... }",
// any reference (tag >= 200) -> "ptr" (opaque pointer, what the host emits for &T).
fn ty_llvm(ty: i64, structs: &Vec<SDef>) -> String ! { alloc } {
    if ty == 500 { let s = "{ i64, i64 }"; clone(&s) }   // v107: Opt<i64> = tagged struct { i64 tag, i64 payload } (checked FIRST: 500 >= 200 would mis-hit ptr)
    else { if ty >= 200 { let p = "ptr"; clone(&p) }
    else { if ty == 3 { let s = "{ ptr, i64, i64 }"; clone(&s) }
    else { if ty == 4 { let s = "{ ptr, i64, i64 }"; clone(&s) }   // Vec<i64> = {data,len,cap}
    else { if ty < 100 { let s = "i64"; clone(&s) }
    else {
        let sd = vec_get(structs, ty - 100);
        let nf = vec_len(&sd.fields);
        let mut out = string_new();
        let open = "{ "; app(&mut out, clone(&open));
        let mut i = 0;
        while i < nf {
            if i > 0 { let sep = ", "; app(&mut out, clone(&sep)); } else { let e = ""; app(&mut out, clone(&e)); }
            let fld = vec_get(&sd.fields, i); let t = ty_llvm(fld.ty, structs); app(&mut out, t);
            i = i + 1;
        }
        let close = " }"; app(&mut out, clone(&close));
        out
    } } } } }
}

// Lower one expression; append instructions; return its value (operand + type).
fn lower(e: &Expr, oenv: &HashMap<String, String>, tenv: &HashMap<String, i64>, menv: &HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>, c: &mut Ctr, buf: &mut String) -> Val ! { alloc } {
    match e {
        Num(v) => Val { op: int_to_string(*v), ty: 1 },
        Var(name) => {
            let o = match hashmap_get(oenv, clone(name)) { Some(x) => x, None => string_new() };
            let t = match hashmap_get(tenv, clone(name)) { Some(x) => x, None => 1 };
            // A mutable local: `oenv` holds its alloca slot; emit a load. Immutable
            // bindings keep the existing SSA-value path (byte-identical).
            let is_mut = match hashmap_get(menv, clone(name)) { Some(m) => m, None => 0 };
            if is_mut == 1 {
                let lt = ty_llvm(t, structs);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = load "); app(buf, clone(&lt)); app(buf, ", ptr "); app(buf, o); app(buf, "\n");
                Val { op: reg(r), ty: t }
            } else {
                Val { op: o, ty: t }
            }
        },
        Bin(op, a, b) => {
            let va = lower(&(**a), oenv, tenv, menv, structs, fns, c, buf);
            let vb = lower(&(**b), oenv, tenv, menv, structs, fns, c, buf);
            let o = *op;
            if o == 10 {
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = add i64 "); app(buf, va.op); app(buf, ", "); app(buf, vb.op); app(buf, "\n");
                Val { op: reg(r), ty: 1 }
            } else { if o == 28 {                                                            // v100: '-'
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = sub i64 "); app(buf, va.op); app(buf, ", "); app(buf, vb.op); app(buf, "\n");
                Val { op: reg(r), ty: 1 }
            } else { if o == 11 {
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = mul i64 "); app(buf, va.op); app(buf, ", "); app(buf, vb.op); app(buf, "\n");
                Val { op: reg(r), ty: 1 }
            } else {
                let pred = if o == 20 { "slt" } else { if o == 22 { "sle" } else { "eq" } };
                let t = fresh(c);
                app(buf, "  "); app(buf, reg(t)); app(buf, " = icmp "); app(buf, pred); app(buf, " i64 "); app(buf, va.op); app(buf, ", "); app(buf, vb.op); app(buf, "\n");
                let z = fresh(c);
                app(buf, "  "); app(buf, reg(z)); app(buf, " = zext i1 "); app(buf, reg(t)); app(buf, " to i64\n");
                Val { op: reg(z), ty: 2 }
            } } }
        },
        If(cc, tt, ee) => {
            let vc = lower(&(**cc), oenv, tenv, menv, structs, fns, c, buf);
            let vt = lower(&(**tt), oenv, tenv, menv, structs, fns, c, buf);
            let ve = lower(&(**ee), oenv, tenv, menv, structs, fns, c, buf);
            let ci = fresh(c);
            app(buf, "  "); app(buf, reg(ci)); app(buf, " = icmp ne i64 "); app(buf, vc.op); app(buf, ", 0\n");
            let r = fresh(c);
            let lt = ty_llvm(vt.ty, structs);
            app(buf, "  "); app(buf, reg(r)); app(buf, " = select i1 "); app(buf, reg(ci));
            app(buf, ", "); app(buf, clone(&lt)); app(buf, " "); app(buf, vt.op);
            app(buf, ", "); app(buf, lt); app(buf, " "); app(buf, ve.op); app(buf, "\n");
            Val { op: reg(r), ty: vt.ty }
        },
        SLit(si, vals) => {
            // v94: a generic struct (gp==1) resolves to its specialized INSTANCE
            // (registered by the monomorphizer). We lower field values first, infer
            // `T` from the first generic field's lowered type, then build the
            // aggregate at the instance's index/type. Monomorphic structs use *si
            // directly and stay byte-identical (Risk R0).
            let sd0 = vec_get(structs, *si);
            let nv = vec_len(vals);
            // lower all field values once (need their concrete types to infer T)
            let mut ops = vec_new(); let mut tys = vec_new();
            let mut li = 0;
            while li < nv { let fv = vec_get(vals, li); let vv = lower(&(*fv), oenv, tenv, menv, structs, fns, c, buf); vec_push(&mut ops, vv.op); vec_push(&mut tys, vv.ty); li = li + 1; }
            // resolve the effective struct index (generic -> instance)
            let eff_si = if sd0.gp == 1 {
                let mut tcur = 0; let mut fi2 = 0;
                while fi2 < nv { let f = vec_get(&sd0.fields, fi2); if tcur == 0 { if f.ty == 0 - 1 { tcur = vec_get(&tys, fi2); } else { if f.ty == 199 { let t = vec_get(&tys, fi2); tcur = if t >= 200 { t - 200 } else { 0 }; } else { let z = 0; } } } else { let z = 0; } fi2 = fi2 + 1; }
                let mn = mangle(&sd0.name, tcur, structs); struct_index(structs, &mn)
            } else { *si };
            let sty = ty_llvm(100 + eff_si, structs);
            let sd = vec_get(structs, eff_si);
            let mut cur = "undef"; let mut curs = clone(&cur);
            let mut i = 0;
            while i < nv {
                let f = vec_get(&sd.fields, i);
                let flt = ty_llvm(f.ty, structs);
                let opi = vec_get(&ops, i);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = insertvalue "); app(buf, clone(&sty)); app(buf, " ");
                app(buf, curs); app(buf, ", "); app(buf, flt); app(buf, " "); app(buf, opi); app(buf, ", "); app(buf, int_to_string(i)); app(buf, "\n");
                curs = reg(r);
                i = i + 1;
            }
            Val { op: curs, ty: 100 + eff_si }
        },
        Field(obj, fname) => {
            let vo = lower(&(**obj), oenv, tenv, menv, structs, fns, c, buf);
            // If the object is a &Struct (tag >= 300), its operand is a `ptr` — load
            // the aggregate first, then extractvalue. A plain struct is unchanged.
            let is_ref = if vo.ty >= 300 { 1 } else { 0 };
            let base = if is_ref == 1 { vo.ty - 200 } else { vo.ty };
            let sty = ty_llvm(base, structs);
            let agg = if is_ref == 1 {
                let ld = fresh(c);
                app(buf, "  "); app(buf, reg(ld)); app(buf, " = load "); app(buf, clone(&sty)); app(buf, ", ptr "); app(buf, vo.op); app(buf, "\n");
                reg(ld)
            } else { vo.op };
            let fi = field_index(structs, base - 100, fname);
            let sd = vec_get(structs, base - 100);
            let f = vec_get(&sd.fields, fi);
            let r = fresh(c);
            app(buf, "  "); app(buf, reg(r)); app(buf, " = extractvalue "); app(buf, sty); app(buf, " ");
            app(buf, agg); app(buf, ", "); app(buf, int_to_string(fi)); app(buf, "\n");
            Val { op: reg(r), ty: f.ty }
        },
        Ref(inner) => {
            // CRITICAL (v92, Risk R1): `&mut <mutable-local>` must yield the local's
            // ACTUAL alloca slot (already a `ptr`), NOT a load+re-alloca copy. Otherwise
            // `vec_push(&mut v, x)` would grow/mutate a throwaway copy and `vec_len(&v)`
            // would read the stale original (len stays 0) and the realloc'd buffer leaks.
            // For a mutable local we have its slot in `oenv` and its tag in `tenv`.
            let is_mut_local = match &(**inner) {
                Var(nm) => { match hashmap_get(menv, clone(nm)) { Some(m) => m, None => 0 } },
                _ => 0,
            };
            if is_mut_local == 1 {
                match &(**inner) {
                    Var(nm) => {
                        let slot = match hashmap_get(oenv, clone(nm)) { Some(x) => x, None => string_new() };
                        let t = match hashmap_get(tenv, clone(nm)) { Some(x) => x, None => 1 };
                        Val { op: slot, ty: 200 + t }
                    },
                    _ => { Val { op: string_new(), ty: 0 } },   // unreachable (is_mut_local guards it)
                }
            } else {
                // `&e`: materialize e into a stack slot and yield its pointer. Inline
                // alloca is valid LLVM (unoptimized); the gate compares exit codes.
                let vi = lower(&(**inner), oenv, tenv, menv, structs, fns, c, buf);
                let ity = ty_llvm(vi.ty, structs);
                let slot = fresh(c);
                app(buf, "  "); app(buf, reg(slot)); app(buf, " = alloca "); app(buf, clone(&ity)); app(buf, "\n");
                app(buf, "  store "); app(buf, ity); app(buf, " "); app(buf, vi.op); app(buf, ", ptr "); app(buf, reg(slot)); app(buf, "\n");
                Val { op: reg(slot), ty: 200 + vi.ty }
            }
        },
        StrLit(start, len) => {
            // Reference the module-preamble global @.str.<start> (id = source offset,
            // unique per literal) and build the host's borrowed-String aggregate
            // { i8* data, i64 len, i64 cap=0 }. cap=0 marks a read-only literal view.
            let nb = *len;
            let dotstr = "@.str."; let sn = int_to_string(*start); let gname = str_concat(&dotstr, &sn);
            let asz = int_to_string(nb + 1);
            let p = fresh(c);
            app(buf, "  "); app(buf, reg(p)); app(buf, " = getelementptr ["); app(buf, clone(&asz)); app(buf, " x i8], ptr "); app(buf, clone(&gname)); app(buf, ", i64 0, i64 0\n");
            let a0 = fresh(c);
            app(buf, "  "); app(buf, reg(a0)); app(buf, " = insertvalue { ptr, i64, i64 } undef, ptr "); app(buf, reg(p)); app(buf, ", 0\n");
            let a1 = fresh(c);
            app(buf, "  "); app(buf, reg(a1)); app(buf, " = insertvalue { ptr, i64, i64 } "); app(buf, reg(a0)); app(buf, ", i64 "); app(buf, int_to_string(nb)); app(buf, ", 1\n");
            let a2 = fresh(c);
            app(buf, "  "); app(buf, reg(a2)); app(buf, " = insertvalue { ptr, i64, i64 } "); app(buf, reg(a1)); app(buf, ", i64 0, 2\n");
            Val { op: reg(a2), ty: 3 }
        },
        Call(name, args) => {
            let kw = "str_len";
            let kw_vnew = "vec_new"; let kw_vpush = "vec_push"; let kw_vget = "vec_get";
            let kw_vlen = "vec_len"; let kw_vset = "vec_set"; let kw_scat = "str_concat";
            let kw_scharat = "str_char_at";
            if str_eq(name, &kw) {
                // str_len(&String): arg0 is a ptr to { ptr, i64, i64 }; load field 1 (len).
                let a = vec_get(args, 0);
                let va = lower(&(*a), oenv, tenv, menv, structs, fns, c, buf);
                let gep = fresh(c);
                app(buf, "  "); app(buf, reg(gep)); app(buf, " = getelementptr { ptr, i64, i64 }, ptr "); app(buf, va.op); app(buf, ", i32 0, i32 1\n");
                let ld = fresh(c);
                app(buf, "  "); app(buf, reg(ld)); app(buf, " = load i64, ptr "); app(buf, reg(gep)); app(buf, "\n");
                Val { op: reg(ld), ty: 1 }
            } else { if str_eq(name, &kw_scharat) {
                // str_char_at(&String, i64) -> i64 (the i-th byte; -1 on OOB).
                let a0 = vec_get(args, 0); let a1 = vec_get(args, 1);
                let v0 = lower(&(*a0), oenv, tenv, menv, structs, fns, c, buf);
                let v1 = lower(&(*a1), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call i64 @kdstr_char_at(ptr "); app(buf, v0.op); app(buf, ", i64 "); app(buf, v1.op); app(buf, ")\n");
                Val { op: reg(r), ty: 1 }
            } else { if str_eq(name, &kw_vnew) {
                // vec_new() -> {ptr,i64,i64} aggregate (an empty Vec<i64>).
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call { ptr, i64, i64 } @kdvec_new_i64()\n");
                Val { op: reg(r), ty: 4 }
            } else { if str_eq(name, &kw_vlen) {
                // vec_len(&Vec<i64>): arg0 is a `ptr` to the {data,len,cap}; call runtime.
                let a = vec_get(args, 0);
                let va = lower(&(*a), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call i64 @kdvec_len_i64(ptr "); app(buf, va.op); app(buf, ")\n");
                Val { op: reg(r), ty: 1 }
            } else { if str_eq(name, &kw_vpush) {
                // vec_push(&mut Vec<i64>, i64): all grow/realloc lives in the runtime def.
                let a0 = vec_get(args, 0); let a1 = vec_get(args, 1);
                let v0 = lower(&(*a0), oenv, tenv, menv, structs, fns, c, buf);
                let v1 = lower(&(*a1), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call i64 @kdvec_push_i64(ptr "); app(buf, v0.op); app(buf, ", i64 "); app(buf, v1.op); app(buf, ")\n");
                Val { op: reg(r), ty: 1 }
            } else { if str_eq(name, &kw_vget) {
                // vec_get(&Vec<i64>, i64) -> i64 (bounds-checked in the runtime).
                let a0 = vec_get(args, 0); let a1 = vec_get(args, 1);
                let v0 = lower(&(*a0), oenv, tenv, menv, structs, fns, c, buf);
                let v1 = lower(&(*a1), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call i64 @kdvec_get_i64(ptr "); app(buf, v0.op); app(buf, ", i64 "); app(buf, v1.op); app(buf, ")\n");
                Val { op: reg(r), ty: 1 }
            } else { if str_eq(name, &kw_vset) {
                // vec_set(&mut Vec<i64>, i64, i64) -> i64 (bounds-checked store).
                let a0 = vec_get(args, 0); let a1 = vec_get(args, 1); let a2 = vec_get(args, 2);
                let v0 = lower(&(*a0), oenv, tenv, menv, structs, fns, c, buf);
                let v1 = lower(&(*a1), oenv, tenv, menv, structs, fns, c, buf);
                let v2 = lower(&(*a2), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call i64 @kdvec_set_i64(ptr "); app(buf, v0.op); app(buf, ", i64 "); app(buf, v1.op); app(buf, ", i64 "); app(buf, v2.op); app(buf, ")\n");
                Val { op: reg(r), ty: 1 }
            } else { if str_eq(name, &kw_scat) {
                // str_concat(&String, &String) -> owned String (cap>0). malloc+2×memcpy
                // in the runtime def; returns the {data,len,cap} aggregate by value.
                let a0 = vec_get(args, 0); let a1 = vec_get(args, 1);
                let v0 = lower(&(*a0), oenv, tenv, menv, structs, fns, c, buf);
                let v1 = lower(&(*a1), oenv, tenv, menv, structs, fns, c, buf);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call { ptr, i64, i64 } @kdstr_concat(ptr "); app(buf, v0.op); app(buf, ", ptr "); app(buf, v1.op); app(buf, ")\n");
                Val { op: reg(r), ty: 3 }
            } else {
                // user call: lower each arg, then emit `call <rty> @name(<pty> <op>, ...)`
                // using the CALLEE's param types so a &String arg prints `ptr`, etc.
                let gi = fn_index(fns, name);
                let g = vec_get(fns, gi);
                let na = vec_len(args);
                let mut ops = vec_new(); let mut atys = vec_new();
                let mut i = 0;
                while i < na { let a = vec_get(args, i); let va = lower(&(*a), oenv, tenv, menv, structs, fns, c, buf); vec_push(&mut ops, va.op); vec_push(&mut atys, va.ty); i = i + 1; }
                // v94: a generic callee (gp==1) is dispatched to its MANGLED instance
                // (`name__<tag>`); `T` is inferred from the first generic-typed arg's
                // lowered type and param/ret types are substituted. Monomorphic calls
                // keep the existing path verbatim (Risk R0).
                let tcur = if g.gp == 1 {
                    let mut tc = 0; let mut pi = 0;
                    while pi < na { let pm = vec_get(&g.params, pi); if tc == 0 { if pm.ty == 0 - 1 { tc = vec_get(&atys, pi); } else { if pm.ty == 199 { let t = vec_get(&atys, pi); tc = if t >= 200 { t - 200 } else { 0 }; } else { let z = 0; } } } else { let z = 0; } pi = pi + 1; }
                    tc
                } else { 0 };
                let cname = if g.gp == 1 { mangle(name, tcur, structs) } else { clone(name) };
                let rtag = if g.gp == 1 { subst_ty(g.ret, tcur) } else { g.ret };
                let rty = ty_llvm(rtag, structs);
                let r = fresh(c);
                app(buf, "  "); app(buf, reg(r)); app(buf, " = call "); app(buf, clone(&rty)); app(buf, " @"); app(buf, cname); app(buf, "(");
                let mut j = 0;
                while j < na {
                    if j > 0 { let sep = ", "; app(buf, clone(&sep)); } else { let e = ""; app(buf, clone(&e)); }
                    let pm = vec_get(&g.params, j); let ptag = if g.gp == 1 { subst_ty(pm.ty, tcur) } else { pm.ty }; let pty = ty_llvm(ptag, structs); let opj = vec_get(&ops, j);
                    app(buf, pty); app(buf, " "); app(buf, opj);
                    j = j + 1;
                }
                app(buf, ")\n");
                Val { op: reg(r), ty: rtag }
            } } } } } } } }
        },
        MethodCall(recv, mname, args) => {
            // v98 STATIC dispatch: emit a DIRECT call to `@StructName_method`, passing
            // the receiver BY REFERENCE (a `ptr` to its storage) as arg 0, then the
            // declared args. Resolve the receiver's static struct type to find the
            // mangled callee (already registered as an ordinary Fn by parse_impls).
            let vr = lower(&(**recv), oenv, tenv, menv, structs, fns, c, buf);
            // The receiver pointer: a &Struct (tag>=300) operand is ALREADY a ptr to
            // the struct; a plain struct VALUE (100..200) is materialized into a slot.
            let is_ref = if vr.ty >= 300 { 1 } else { 0 };
            let base = if is_ref == 1 { vr.ty - 200 } else { vr.ty };
            let recv_ptr = if is_ref == 1 { vr.op } else {
                let sty = ty_llvm(base, structs);
                let slot = fresh(c);
                app(buf, "  "); app(buf, reg(slot)); app(buf, " = alloca "); app(buf, clone(&sty)); app(buf, "\n");
                app(buf, "  store "); app(buf, sty); app(buf, " "); app(buf, vr.op); app(buf, ", ptr "); app(buf, reg(slot)); app(buf, "\n");
                reg(slot)
            };
            let sd = vec_get(structs, base - 100);
            let sep = "_"; let a = str_concat(&sd.name, &sep); let mn = str_concat(&a, mname);
            let gi = fn_index(fns, &mn);
            let g = vec_get(fns, gi);
            // lower each declared arg (params[0] is self -> recv_ptr; rest = args)
            let na = vec_len(args);
            let mut ops = vec_new();
            let mut i = 0;
            while i < na { let av = vec_get(args, i); let va = lower(&(*av), oenv, tenv, menv, structs, fns, c, buf); vec_push(&mut ops, va.op); i = i + 1; }
            let rty = ty_llvm(g.ret, structs);
            let r = fresh(c);
            app(buf, "  "); app(buf, reg(r)); app(buf, " = call "); app(buf, clone(&rty)); app(buf, " @"); app(buf, mn); app(buf, "(ptr "); app(buf, recv_ptr);
            let mut j = 0;
            while j < na {
                let sep2 = ", "; app(buf, clone(&sep2));
                let pm = vec_get(&g.params, j + 1); let pty = ty_llvm(pm.ty, structs); let opj = vec_get(&ops, j);
                app(buf, pty); app(buf, " "); app(buf, opj);
                j = j + 1;
            }
            app(buf, ")\n");
            Val { op: reg(r), ty: g.ret }
        },
        ECon(tag, eargs) => {
            // v107: build the tagged struct { i64 tag, i64 payload }. Just(x) = {0, x};
            // Nope = {1, undef}. Mirrors SLit's insertvalue chain (payload lowered first).
            if *tag == 0 {
                let a = vec_get(eargs, 0);
                let va = lower(&(*a), oenv, tenv, menv, structs, fns, c, buf);
                let r0 = fresh(c);
                app(buf, "  "); app(buf, reg(r0)); app(buf, " = insertvalue { i64, i64 } undef, i64 0, 0\n");
                let r1 = fresh(c);
                app(buf, "  "); app(buf, reg(r1)); app(buf, " = insertvalue { i64, i64 } "); app(buf, reg(r0)); app(buf, ", i64 "); app(buf, va.op); app(buf, ", 1\n");
                Val { op: reg(r1), ty: 500 }
            } else {
                let r0 = fresh(c);
                app(buf, "  "); app(buf, reg(r0)); app(buf, " = insertvalue { i64, i64 } undef, i64 1, 0\n");
                Val { op: reg(r0), ty: 500 }
            }
        },
        Match(scrut, jb, jbody, nbody) => {
            // v107: lower the scrutinee (an Opt<i64> value), extract tag (field 0) and
            // payload (field 1); bind the Just binder to the payload in CHILD env copies;
            // lower BOTH arm bodies; `select` on tag==0. Mirrors If's select form — so
            // match/if expressions emit NO branches (single basic block), and nested
            // matches compose. (Side-effecting arms would need branch+phi: deferred.)
            let vs = lower(&(**scrut), oenv, tenv, menv, structs, fns, c, buf);
            let so = vs.op;
            let tgr = fresh(c);
            app(buf, "  "); app(buf, reg(tgr)); app(buf, " = extractvalue { i64, i64 } "); app(buf, clone(&so)); app(buf, ", 0\n");
            let plr = fresh(c);
            app(buf, "  "); app(buf, reg(plr)); app(buf, " = extractvalue { i64, i64 } "); app(buf, so); app(buf, ", 1\n");
            let mut oenv2 = clone(oenv); let mut tenv2 = clone(tenv);
            hashmap_insert(&mut oenv2, clone(jb), reg(plr));
            hashmap_insert(&mut tenv2, clone(jb), 1);
            let vj = lower(&(**jbody), &oenv2, &tenv2, menv, structs, fns, c, buf);
            let vn = lower(&(**nbody), oenv, tenv, menv, structs, fns, c, buf);
            let ci = fresh(c);
            app(buf, "  "); app(buf, reg(ci)); app(buf, " = icmp eq i64 "); app(buf, reg(tgr)); app(buf, ", 0\n");
            let bt = ty_llvm(vj.ty, structs);
            let r = fresh(c);
            app(buf, "  "); app(buf, reg(r)); app(buf, " = select i1 "); app(buf, reg(ci)); app(buf, ", "); app(buf, clone(&bt)); app(buf, " "); app(buf, vj.op); app(buf, ", "); app(buf, bt); app(buf, " "); app(buf, vn.op); app(buf, "\n");
            Val { op: reg(r), ty: vj.ty }
        },
    }
}

// Walk an expr, emitting an `@.str.<offset>` global for each string literal into
// the module preamble. id = source byte-offset (unique per literal occurrence).
fn collect_strs(e: &Expr, src: &String, pre: &mut String) ! { alloc } {
    match e {
        Num(_) => { let z = 0; },
        Var(_) => { let z = 0; },
        Bin(_, a, b) => { collect_strs(&(**a), src, pre); collect_strs(&(**b), src, pre); },
        If(c, t, e2) => { collect_strs(&(**c), src, pre); collect_strs(&(**t), src, pre); collect_strs(&(**e2), src, pre); },
        SLit(_, vals) => { let nv = vec_len(vals); let mut i = 0; while i < nv { let v = vec_get(vals, i); collect_strs(&(*v), src, pre); i = i + 1; } },
        Field(obj, _) => { collect_strs(&(**obj), src, pre); },
        Ref(inner) => { collect_strs(&(**inner), src, pre); },
        Call(_, args) => { let na = vec_len(args); let mut i = 0; while i < na { let a = vec_get(args, i); collect_strs(&(*a), src, pre); i = i + 1; } },
        StrLit(start, len) => {
            let bytes = str_substring(src, *start, *len);
            let dotstr = "@.str."; let sn = int_to_string(*start); let gname = str_concat(&dotstr, &sn);
            let asz = int_to_string(*len + 1);
            app(pre, gname); app(pre, " = private unnamed_addr constant ["); app(pre, asz);
            app(pre, " x i8] c\""); app(pre, bytes); app(pre, "\\00\"\n");   // MVP: literals are plain ASCII (no \\ or ")
        },
        MethodCall(recv, _, args) => { collect_strs(&(**recv), src, pre); let na = vec_len(args); let mut i = 0; while i < na { let a = vec_get(args, i); collect_strs(&(*a), src, pre); i = i + 1; } },
        ECon(_, eargs) => { let na = vec_len(eargs); let mut i = 0; while i < na { let a = vec_get(eargs, i); collect_strs(&(*a), src, pre); i = i + 1; } },
        Match(scrut, _, jbody, nbody) => { collect_strs(&(**scrut), src, pre); collect_strs(&(**jbody), src, pre); collect_strs(&(**nbody), src, pre); },
    }
}
fn collect_strs_stmts(stmts: &Vec<Stmt>, src: &String, pre: &mut String) ! { alloc } {
    let nl = vec_len(stmts); let mut k = 0;
    while k < nl {
        let s = vec_get(stmts, k);
        match s {
            Let(_, e) => { collect_strs(&(*e), src, pre); },
            LetMut(_, e) => { collect_strs(&(*e), src, pre); },
            Assign(_, e) => { collect_strs(&(*e), src, pre); },
            While(cond, body) => { collect_strs(&(*cond), src, pre); collect_strs_stmts(&body, src, pre); },
            IfS(cond, then_b, else_b) => { collect_strs(&(*cond), src, pre); collect_strs_stmts(&then_b, src, pre); collect_strs_stmts(&else_b, src, pre); },
            Break => { let z = 0; },
            Continue => { let z = 0; },
            ExprStmt(e) => { collect_strs(&(*e), src, pre); },
        }
        k = k + 1;
    }
}
fn collect_strs_block(b: &Block, src: &String, pre: &mut String) ! { alloc } {
    collect_strs_stmts(&b.lets, src, pre);
    collect_strs(&(*b.result), src, pre);
}

// ---- v92: detect whether a program uses the Vec / str_concat builtins, so the
// runtime defines are emitted ONLY when needed (keeps every prior gate's output
// byte-identical — Risk R0). `kind` selects the family: 1 = any vec_* call,
// 2 = str_concat. Walk mirrors collect_strs's recursion exactly.
fn expr_uses_rt(e: &Expr, kind: i64) -> i64 ! { alloc } {
    match e {
        Num(_) => 0,
        Var(_) => 0,
        Bin(_, a, b) => { if expr_uses_rt(&(**a), kind) == 1 { 1 } else { expr_uses_rt(&(**b), kind) } },
        If(c, t, e2) => { if expr_uses_rt(&(**c), kind) == 1 { 1 } else { if expr_uses_rt(&(**t), kind) == 1 { 1 } else { expr_uses_rt(&(**e2), kind) } } },
        SLit(_, vals) => { let nv = vec_len(vals); let mut i = 0; let mut f = 0; while i < nv { let v = vec_get(vals, i); f = if expr_uses_rt(&(*v), kind) == 1 { 1 } else { f }; i = i + 1; } f },
        Field(obj, _) => { expr_uses_rt(&(**obj), kind) },
        Ref(inner) => { expr_uses_rt(&(**inner), kind) },
        Call(nm, args) => {
            let here = if kind == 1 {
                // any vec_* op (new/push/get/len/set)
                let a = "vec_new"; let b = "vec_push"; let c = "vec_get"; let d = "vec_len"; let e2 = "vec_set";
                if str_eq(nm, &a) { 1 } else { if str_eq(nm, &b) { 1 } else { if str_eq(nm, &c) { 1 } else { if str_eq(nm, &d) { 1 } else { if str_eq(nm, &e2) { 1 } else { 0 } } } } }
            } else { let s = "str_concat"; let s2 = "str_char_at"; if str_eq(nm, &s) { 1 } else { if str_eq(nm, &s2) { 1 } else { 0 } } };
            if here == 1 { 1 } else {
                let na = vec_len(args); let mut i = 0; let mut f = 0;
                while i < na { let a = vec_get(args, i); f = if expr_uses_rt(&(*a), kind) == 1 { 1 } else { f }; i = i + 1; } f
            }
        },
        StrLit(_, _) => 0,
        MethodCall(recv, _, args) => {
            if expr_uses_rt(&(**recv), kind) == 1 { 1 } else {
                let na = vec_len(args); let mut i = 0; let mut f = 0;
                while i < na { let a = vec_get(args, i); f = if expr_uses_rt(&(*a), kind) == 1 { 1 } else { f }; i = i + 1; } f
            }
        },
        ECon(_, eargs) => { let na = vec_len(eargs); let mut i = 0; let mut f = 0; while i < na { let a = vec_get(eargs, i); f = if expr_uses_rt(&(*a), kind) == 1 { 1 } else { f }; i = i + 1; } f },
        Match(scrut, _, jbody, nbody) => { if expr_uses_rt(&(**scrut), kind) == 1 { 1 } else { if expr_uses_rt(&(**jbody), kind) == 1 { 1 } else { expr_uses_rt(&(**nbody), kind) } } },
    }
}
fn stmts_use_rt(stmts: &Vec<Stmt>, kind: i64) -> i64 ! { alloc } {
    let nl = vec_len(stmts); let mut k = 0; let mut f = 0;
    while k < nl {
        let s = vec_get(stmts, k);
        let h = match s {
            Let(_, e) => { expr_uses_rt(&(*e), kind) },
            LetMut(_, e) => { expr_uses_rt(&(*e), kind) },
            Assign(_, e) => { expr_uses_rt(&(*e), kind) },
            While(cond, body) => { if expr_uses_rt(&(*cond), kind) == 1 { 1 } else { stmts_use_rt(&body, kind) } },
            IfS(cond, then_b, else_b) => { if expr_uses_rt(&(*cond), kind) == 1 { 1 } else { if stmts_use_rt(&then_b, kind) == 1 { 1 } else { stmts_use_rt(&else_b, kind) } } },
            Break => 0,
            Continue => 0,
            ExprStmt(e) => { expr_uses_rt(&(*e), kind) },
        };
        f = if h == 1 { 1 } else { f };
        k = k + 1;
    }
    f
}
fn block_uses_rt(b: &Block, kind: i64) -> i64 ! { alloc } {
    if stmts_use_rt(&b.lets, kind) == 1 { 1 } else { expr_uses_rt(&(*b.result), kind) }
}
// Scan ALL fns for a given runtime family.
fn fns_use_rt(fns: &Vec<Fn>, kind: i64) -> i64 ! { alloc } {
    let nf = vec_len(fns); let mut i = 0; let mut f = 0;
    while i < nf { let g = vec_get(fns, i); f = if block_uses_rt(&g.body, kind) == 1 { 1 } else { f }; i = i + 1; }
    f
}

// Emit the self-contained Vec<i64> / growable-String runtime into the module
// preamble — libc `declare`s + the `kdvec_*` / `kdstr_*` `define`s — ONLY when the
// program actually uses them. clang links libc by default, so malloc/realloc/free/
// memcpy resolve standalone (no kardashev runtime linked). Emitting nothing when
// unused keeps the v84-v91 gate outputs byte-for-byte identical (Risk R0).
fn emit_runtime_decls(pre: &mut String, want_vec: i64, want_str: i64) ! { alloc } {
    let any = if want_vec == 1 { 1 } else { if want_str == 1 { 1 } else { 0 } };
    if any == 1 {
    // libc declarations (shared by Vec + String runtime).
    app(pre, "declare ptr @malloc(i64)\n");
    app(pre, "declare ptr @realloc(ptr, i64)\n");
    app(pre, "declare void @free(ptr)\n");
    app(pre, "declare ptr @memcpy(ptr, ptr, i64)\n");
    if want_vec == 1 {
        // Vec<i64> = { ptr data, i64 len, i64 cap }; doubling growth from cap 0->4.
        app(pre, "define { ptr, i64, i64 } @kdvec_new_i64() {\nentry:\n  ret { ptr, i64, i64 } { ptr null, i64 0, i64 0 }\n}\n");
        app(pre, "define i64 @kdvec_len_i64(ptr %v) {\nentry:\n  %p = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 1\n  %l = load i64, ptr %p\n  ret i64 %l\n}\n");
        app(pre, "define i64 @kdvec_push_i64(ptr %v, i64 %x) {\nentry:\n  %lenp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 1\n  %capp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 2\n  %datp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 0\n  %len = load i64, ptr %lenp\n  %cap = load i64, ptr %capp\n  %full = icmp eq i64 %len, %cap\n  br i1 %full, label %grow, label %store\ngrow:\n  %capz = icmp eq i64 %cap, 0\n  %dbl = mul i64 %cap, 2\n  %nc = select i1 %capz, i64 4, i64 %dbl\n  %olddat = load ptr, ptr %datp\n  %bytes = mul i64 %nc, 8\n  %nd = call ptr @realloc(ptr %olddat, i64 %bytes)\n  store ptr %nd, ptr %datp\n  store i64 %nc, ptr %capp\n  br label %store\nstore:\n  %data = load ptr, ptr %datp\n  %slot = getelementptr i64, ptr %data, i64 %len\n  store i64 %x, ptr %slot\n  %len1 = add i64 %len, 1\n  store i64 %len1, ptr %lenp\n  ret i64 0\n}\n");
        app(pre, "define i64 @kdvec_get_i64(ptr %v, i64 %i) {\nentry:\n  %lenp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 1\n  %datp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 0\n  %len = load i64, ptr %lenp\n  %neg = icmp slt i64 %i, 0\n  %big = icmp sge i64 %i, %len\n  %oob = or i1 %neg, %big\n  br i1 %oob, label %bad, label %ok\nbad:\n  ret i64 0\nok:\n  %data = load ptr, ptr %datp\n  %slot = getelementptr i64, ptr %data, i64 %i\n  %r = load i64, ptr %slot\n  ret i64 %r\n}\n");
        app(pre, "define i64 @kdvec_set_i64(ptr %v, i64 %i, i64 %x) {\nentry:\n  %lenp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 1\n  %datp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 0\n  %len = load i64, ptr %lenp\n  %neg = icmp slt i64 %i, 0\n  %big = icmp sge i64 %i, %len\n  %oob = or i1 %neg, %big\n  br i1 %oob, label %bad, label %ok\nbad:\n  ret i64 0\nok:\n  %data = load ptr, ptr %datp\n  %slot = getelementptr i64, ptr %data, i64 %i\n  store i64 %x, ptr %slot\n  ret i64 0\n}\n");
        app(pre, "define void @kdvec_drop_i64(ptr %v) {\nentry:\n  %datp = getelementptr { ptr, i64, i64 }, ptr %v, i32 0, i32 0\n  %data = load ptr, ptr %datp\n  call void @free(ptr %data)\n  ret void\n}\n");
    } else { let z = 0; }
    if want_str == 1 {
        // str_char_at(&String, i64) -> i64: the i-th byte (0..255), -1 if OOB.
        // Mirrors the host's clamp-OOB-to-(-1) so the differential gate holds.
        app(pre, "define i64 @kdstr_char_at(ptr %s, i64 %i) {\nentry:\n  %lenp = getelementptr { ptr, i64, i64 }, ptr %s, i32 0, i32 1\n  %datp = getelementptr { ptr, i64, i64 }, ptr %s, i32 0, i32 0\n  %len = load i64, ptr %lenp\n  %neg = icmp slt i64 %i, 0\n  %big = icmp sge i64 %i, %len\n  %oob = or i1 %neg, %big\n  br i1 %oob, label %bad, label %ok\nbad:\n  ret i64 -1\nok:\n  %data = load ptr, ptr %datp\n  %bp = getelementptr i8, ptr %data, i64 %i\n  %byte = load i8, ptr %bp\n  %z = zext i8 %byte to i64\n  ret i64 %z\n}\n");
        // String = { ptr data, i64 len, i64 cap }; concat mallocs len(a)+len(b)+1,
        // memcpys both halves, returns an owned (cap>0) value. drop frees iff cap>0.
        app(pre, "define { ptr, i64, i64 } @kdstr_concat(ptr %a, ptr %b) {\nentry:\n  %ad = getelementptr { ptr, i64, i64 }, ptr %a, i32 0, i32 0\n  %al = getelementptr { ptr, i64, i64 }, ptr %a, i32 0, i32 1\n  %bd = getelementptr { ptr, i64, i64 }, ptr %b, i32 0, i32 0\n  %bl = getelementptr { ptr, i64, i64 }, ptr %b, i32 0, i32 1\n  %adp = load ptr, ptr %ad\n  %alen = load i64, ptr %al\n  %bdp = load ptr, ptr %bd\n  %blen = load i64, ptr %bl\n  %tot = add i64 %alen, %blen\n  %cap = add i64 %tot, 1\n  %nb = call ptr @malloc(i64 %cap)\n  %c1 = call ptr @memcpy(ptr %nb, ptr %adp, i64 %alen)\n  %tail = getelementptr i8, ptr %nb, i64 %alen\n  %c2 = call ptr @memcpy(ptr %tail, ptr %bdp, i64 %blen)\n  %r0 = insertvalue { ptr, i64, i64 } undef, ptr %nb, 0\n  %r1 = insertvalue { ptr, i64, i64 } %r0, i64 %tot, 1\n  %r2 = insertvalue { ptr, i64, i64 } %r1, i64 %cap, 2\n  ret { ptr, i64, i64 } %r2\n}\n");
        app(pre, "define void @kdstr_drop(ptr %s) {\nentry:\n  %capp = getelementptr { ptr, i64, i64 }, ptr %s, i32 0, i32 2\n  %cap = load i64, ptr %capp\n  %owned = icmp ne i64 %cap, 0\n  br i1 %owned, label %dofree, label %done\ndofree:\n  %datp = getelementptr { ptr, i64, i64 }, ptr %s, i32 0, i32 0\n  %data = load ptr, ptr %datp\n  call void @free(ptr %data)\n  br label %done\ndone:\n  ret void\n}\n");
    } else { let z = 0; }
    } else { let z = 0; }
}

// True if `slot` already appears in the owned-drop list (avoid double-free when a
// `let mut s` is later reassigned a `str_concat` — it was already tracked at decl
// or a prior assign).
fn slot_tracked(owned: &Vec<String>, slot: &String) -> i64 ! { alloc } {
    let n = vec_len(owned); let mut i = 0; let mut found = 0;
    while i < n { let s = vec_get(owned, i); found = if str_eq(&s, slot) { 1 } else { found }; i = i + 1; }
    found
}

// True if `e` is a `str_concat(...)` call — i.e. it produces an OWNED (cap>0)
// String (vs a borrowed literal / string_new). Used to decide whether a `let mut`
// String local needs an exit-time free (v92 Drop discipline).
fn is_str_concat(e: &Expr) -> i64 ! { alloc } {
    match e {
        Call(nm, args) => { let kw = "str_concat"; if str_eq(nm, &kw) { 1 } else { 0 } },
        Num(_) => 0,
        Var(_) => 0,
        Bin(_, _, _) => 0,
        If(_, _, _) => 0,
        SLit(_, _) => 0,
        Field(_, _) => 0,
        Ref(_) => 0,
        StrLit(_, _) => 0,
        MethodCall(_, _, _) => 0,
        ECon(_, _) => 0,
        Match(_, _, _, _) => 0,
    }
}

// Lower one statement into the current basic block, threading codegen state.
// oenv/tenv/menv are mutated for new bindings; `loops` is the enclosing-loop
// branch-target stack; `cg.termd` tracks whether the current block is terminated.
fn lower_stmt(s: &Stmt, oenv: &mut HashMap<String, String>, tenv: &mut HashMap<String, i64>, menv: &mut HashMap<String, i64>, structs: &Vec<SDef>, fns: &Vec<Fn>, c: &mut Ctr, loops: &mut Vec<LoopCtx>, cg: &mut CgState, buf: &mut String) ! { alloc } {
    // After a break/continue terminated the block, open a fresh (dead) block so
    // any following instructions are still well-formed LLVM.
    if cg.termd == 1 {
        let dn = fresh(c); let stem = "dead.";
        app(buf, label(&stem, dn)); app(buf, ":\n");
        cg.termd = 0;
    } else { let z = 0; }
    match s {
        Let(name, e) => {
            let v = lower(&(**e), oenv, tenv, menv, structs, fns, c, buf);
            hashmap_insert(tenv, clone(name), v.ty);
            hashmap_insert(oenv, clone(name), v.op);
        },
        LetMut(name, e) => {
            let v = lower(&(**e), oenv, tenv, menv, structs, fns, c, buf);
            let lt = ty_llvm(v.ty, structs);
            let slot = fresh(c);
            app(buf, "  "); app(buf, reg(slot)); app(buf, " = alloca "); app(buf, clone(&lt)); app(buf, "\n");
            app(buf, "  store "); app(buf, clone(&lt)); app(buf, " "); app(buf, v.op); app(buf, ", ptr "); app(buf, reg(slot)); app(buf, "\n");
            hashmap_insert(tenv, clone(name), v.ty);
            hashmap_insert(oenv, clone(name), reg(slot));
            hashmap_insert(menv, clone(name), 1);
            // v92 Drop tracking: a `let mut` Vec<i64> (tag 4) is always owned; a
            // `let mut` String (tag 3) is owned iff initialized by str_concat. Track
            // the SLOT so emit_fn frees it once before `ret`. (Owned-string drop is
            // cap-gated at runtime, so an initially-borrowed `let mut s = ""` that is
            // later reassigned a str_concat is also tracked at that assign below.)
            if v.ty == 4 { vec_push(&mut cg.owned, reg(slot)); vec_push(&mut cg.owned_ty, 4); }
            else { if v.ty == 3 { if is_str_concat(&(**e)) == 1 { vec_push(&mut cg.owned, reg(slot)); vec_push(&mut cg.owned_ty, 3); } else { let z = 0; } } else { let z = 0; } }
        },
        Assign(name, e) => {
            let v = lower(&(**e), oenv, tenv, menv, structs, fns, c, buf);
            let t = match hashmap_get(tenv, clone(name)) { Some(x) => x, None => 1 };
            let lt = ty_llvm(t, structs);
            let slot = match hashmap_get(oenv, clone(name)) { Some(x) => x, None => string_new() };
            app(buf, "  store "); app(buf, clone(&lt)); app(buf, " "); app(buf, v.op); app(buf, ", ptr "); app(buf, clone(&slot)); app(buf, "\n");
            // v92: an `s = str_concat(...)` makes `s` own a heap buffer — track its
            // slot for exit-time free if not already tracked. (The PRIOR value the
            // slot held is overwritten/leaked: drop-on-reassign needs liveness and is
            // a documented v92 deferral; only the FINAL value is freed at exit.)
            if t == 3 { if is_str_concat(&(**e)) == 1 { if slot_tracked(&cg.owned, &slot) == 0 { vec_push(&mut cg.owned, clone(&slot)); vec_push(&mut cg.owned_ty, 3); } else { let z = 0; } } else { let z = 0; } } else { let z = 0; }
        },
        While(cond, body) => {
            let stem_h = "loop.header."; let stem_b = "loop.body."; let stem_x = "loop.exit.";
            let hn = fresh(c); let bn = fresh(c); let xn = fresh(c);
            // entry -> header
            app(buf, "  br label "); app(buf, label_ref(&stem_h, hn)); app(buf, "\n");
            app(buf, label(&stem_h, hn)); app(buf, ":\n");
            // header: evaluate condition, branch to body/exit
            let vc = lower(&(**cond), oenv, tenv, menv, structs, fns, c, buf);
            let ci = fresh(c);
            app(buf, "  "); app(buf, reg(ci)); app(buf, " = icmp ne i64 "); app(buf, vc.op); app(buf, ", 0\n");
            app(buf, "  br i1 "); app(buf, reg(ci)); app(buf, ", label "); app(buf, label_ref(&stem_b, bn)); app(buf, ", label "); app(buf, label_ref(&stem_x, xn)); app(buf, "\n");
            // body
            app(buf, label(&stem_b, bn)); app(buf, ":\n");
            vec_push(loops, LoopCtx { header: hn, exit: xn });
            cg.termd = 0;
            let nb = vec_len(body);
            let mut bi = 0;
            while bi < nb {
                let bs = vec_get(body, bi);
                lower_stmt(&bs, oenv, tenv, menv, structs, fns, c, loops, cg, buf);
                bi = bi + 1;
            }
            // body falls through back to the header (unless it already terminated)
            if cg.termd == 0 { app(buf, "  br label "); app(buf, label_ref(&stem_h, hn)); app(buf, "\n"); } else { let z = 0; }
            let dropped = vec_pop(loops);
            // exit block becomes current
            app(buf, label(&stem_x, xn)); app(buf, ":\n");
            cg.termd = 0;
        },
        IfS(cond, then_b, else_b) => {
            let stem_t = "if.then."; let stem_e = "if.else."; let stem_d = "if.end.";
            let tn = fresh(c); let en = fresh(c); let dn = fresh(c);
            let vc = lower(&(**cond), oenv, tenv, menv, structs, fns, c, buf);
            let ci = fresh(c);
            app(buf, "  "); app(buf, reg(ci)); app(buf, " = icmp ne i64 "); app(buf, vc.op); app(buf, ", 0\n");
            app(buf, "  br i1 "); app(buf, reg(ci)); app(buf, ", label "); app(buf, label_ref(&stem_t, tn)); app(buf, ", label "); app(buf, label_ref(&stem_e, en)); app(buf, "\n");
            // then
            app(buf, label(&stem_t, tn)); app(buf, ":\n"); cg.termd = 0;
            let nt = vec_len(then_b); let mut ti = 0;
            while ti < nt { let ts = vec_get(then_b, ti); lower_stmt(&ts, oenv, tenv, menv, structs, fns, c, loops, cg, buf); ti = ti + 1; }
            if cg.termd == 0 { app(buf, "  br label "); app(buf, label_ref(&stem_d, dn)); app(buf, "\n"); } else { let z = 0; }
            // else
            app(buf, label(&stem_e, en)); app(buf, ":\n"); cg.termd = 0;
            let ne = vec_len(else_b); let mut ei = 0;
            while ei < ne { let es = vec_get(else_b, ei); lower_stmt(&es, oenv, tenv, menv, structs, fns, c, loops, cg, buf); ei = ei + 1; }
            if cg.termd == 0 { app(buf, "  br label "); app(buf, label_ref(&stem_d, dn)); app(buf, "\n"); } else { let z = 0; }
            // end (join) block becomes current
            app(buf, label(&stem_d, dn)); app(buf, ":\n"); cg.termd = 0;
        },
        Break => {
            let nl = vec_len(loops);
            if nl > 0 {
                let lc = vec_get(loops, nl - 1); let stem_x = "loop.exit.";
                app(buf, "  br label "); app(buf, label_ref(&stem_x, lc.exit)); app(buf, "\n");
                cg.termd = 1;
            } else { let z = 0; }
        },
        Continue => {
            let nl = vec_len(loops);
            if nl > 0 {
                let lc = vec_get(loops, nl - 1); let stem_h = "loop.header.";
                app(buf, "  br label "); app(buf, label_ref(&stem_h, lc.header)); app(buf, "\n");
                cg.termd = 1;
            } else { let z = 0; }
        },
        ExprStmt(e) => {
            // Lower the expr for its side effect (e.g. vec_push / vec_set);
            // the produced value is discarded.
            let v = lower(&(**e), oenv, tenv, menv, structs, fns, c, buf);
            let z = 0;
        },
    }
}

// Emit one fn DEFINITION. v94: `tcur` is the concrete tag bound to `T` (0 for a
// monomorphic fn — then subst_ty is a no-op and the override name is empty, so the
// output is byte-identical), and `mname` overrides the emitted symbol name for a
// generic instance (e.g. `id__i64`). The body is the SHARED generic AST; type
// resolution happens through the SUBSTITUTED param/ret tags (no AST clone needed).
fn emit_fn(f: &Fn, structs: &Vec<SDef>, fns: &Vec<Fn>, buf: &mut String) ! { alloc } {
    let empty = ""; emit_fn_inst(f, 0, &empty, structs, fns, buf);
}
fn emit_fn_inst(f: &Fn, tcur: i64, mname: &String, structs: &Vec<SDef>, fns: &Vec<Fn>, buf: &mut String) ! { alloc } {
    let ret_tag = subst_ty(f.ret, tcur);
    let rty = ty_llvm(ret_tag, structs);
    let sym = if str_len(mname) > 0 { clone(mname) } else { clone(&f.name) };
    app(buf, "define "); app(buf, clone(&rty)); app(buf, " @"); app(buf, sym); app(buf, "(");
    let np = vec_len(&f.params);
    let mut oenv = hashmap_new();
    let mut tenv = hashmap_new();
    let mut menv = hashmap_new();          // name -> 1 if a mutable local (alloca slot in oenv)
    let mut i = 0;
    while i < np {
        if i > 0 { app(buf, ", "); } else { app(buf, ""); }
        let p = vec_get(&f.params, i);
        let p_tag = subst_ty(p.ty, tcur);
        let pty = ty_llvm(p_tag, structs);
        let an = arg_name(i);
        app(buf, clone(&pty)); app(buf, " "); app(buf, clone(&an));
        hashmap_insert(&mut oenv, clone(&p.name), an);
        hashmap_insert(&mut tenv, clone(&p.name), p_tag);
        i = i + 1;
    }
    app(buf, ") {\nentry:\n");
    let mut c = Ctr { n: 0 };
    let mut loops = vec_new();
    let mut cg = CgState { termd: 0, owned: vec_new(), owned_ty: vec_new() };
    let nl = vec_len(&f.body.lets);
    let mut k = 0;
    while k < nl {
        let s = vec_get(&f.body.lets, k);
        lower_stmt(&s, &mut oenv, &mut tenv, &mut menv, structs, fns, &mut c, &mut loops, &mut cg, buf);
        k = k + 1;
    }
    // The block-result expression. If the prior statement left the block
    // terminated (e.g. trailing break/continue — not valid as a fn body, but
    // guard anyway), open a fresh block first.
    if cg.termd == 1 { let dn = fresh(&mut c); let stem = "dead."; app(buf, label(&stem, dn)); app(buf, ":\n"); cg.termd = 0; } else { let z = 0; }
    let res = lower(&(*f.body.result), &oenv, &tenv, &menv, structs, fns, &mut c, buf);
    // v92 Drop discipline: free each non-escaping owned heap local (Vec<i64> /
    // owned String) once, here at the single fn exit (the emitted subset has no
    // early `return`, so one free-block suffices — Risk R2). The result is already
    // an SSA i64 value, so freeing the buffers now cannot affect it. We SKIP frees
    // entirely when f itself returns an owned-heap type (3/4): returning a Vec /
    // owned String transfers ownership to the caller and is a documented v92
    // deferral (Risk R3) — never freed here to avoid a use-after-free.
    let escapes = if ret_tag == 3 { 1 } else { if ret_tag == 4 { 1 } else { 0 } };
    if escapes == 0 {
        let no = vec_len(&cg.owned); let mut oi = 0;
        while oi < no {
            let slot = vec_get(&cg.owned, oi); let oty = vec_get(&cg.owned_ty, oi);
            if oty == 4 { app(buf, "  call void @kdvec_drop_i64(ptr "); app(buf, slot); app(buf, ")\n"); }
            else { app(buf, "  call void @kdstr_drop(ptr "); app(buf, slot); app(buf, ")\n"); }
            oi = oi + 1;
        }
    } else { let z = 0; }
    app(buf, "  ret "); app(buf, rty); app(buf, " "); app(buf, res.op); app(buf, "\n}\n");
}
fn emit_main(f: &Fn, args: &Vec<i64>, structs: &Vec<SDef>, buf: &mut String) ! { alloc } {
    let rty = ty_llvm(f.ret, structs);
    app(buf, "define i64 @main() {\nentry:\n  %r = call "); app(buf, clone(&rty)); app(buf, " @"); app(buf, clone(&f.name)); app(buf, "(");
    let np = vec_len(&f.params);
    let mut i = 0;
    while i < np {
        if i > 0 { app(buf, ", "); } else { app(buf, ""); }
        let a = vec_get(args, i);
        app(buf, "i64 "); app(buf, int_to_string(a));
        i = i + 1;
    }
    app(buf, ")\n");
    // The exit code must be i64. If f returns a struct, use its field 0.
    if f.ret >= 100 { app(buf, "  %rx = extractvalue "); app(buf, rty); app(buf, " %r, 0\n  ret i64 %rx\n}\n"); }
    else { app(buf, "  ret i64 %r\n}\n"); }
}

fn main() -> i64 ! { io, alloc } {
    // struct P { x, y } ; f(a,b) builds P { x: a, y: b } and returns p.x + p.y.
    let demo = "struct P { x: i64, y: i64 } fn f(a: i64, b: i64) -> i64 { let p = P { x: a, y: b } ; p.x + p.y }";
    let mut src = string_new();
    if arg_count() > 1 { src = arg_get(1); } else { src = clone(&demo); }
    let toks = lex(&src);
    let mut pos = Pos { i: 0 };
    let mut structs = parse_structs(&src, &toks, &mut pos);
    // v107: consume any enum declarations (the fixed Opt<T> shape) right after structs.
    skip_enum_decls(&src, &toks, &mut pos);
    // v98: parse trait declarations (signatures only — consumed) then impl blocks,
    // BEFORE the fns loop. Each impl method is registered into `fns` under a mangled
    // `StructName_method` name, so the existing emit_fn loop emits it and the static
    // dispatch lowering can call it directly. Convention: structs -> traits -> impls
    // -> fns (structgen requires structs declared first).
    parse_traits(&src, &toks, &mut pos);
    let mut fns = vec_new();
    parse_impls(&src, &toks, &mut pos, &structs, &mut fns);
    // Parse ALL top-level fns into a registry (user calls need every callee).
    let kw_fn = "fn";
    let mut more = true;
    while more {
        let is_fn = at_kw(&src, &toks, &pos, &kw_fn);
        if is_fn == 1 { let g = parse_fn(&src, &toks, &mut pos, &structs); vec_push(&mut fns, g); }
        else { more = false; }
    }
    // v94: monomorphize generic STRUCTS first — register one specialized SDef per
    // (generic-struct, concrete-T) used by a non-generic fn, so the typechecker /
    // codegen below resolve a generic struct literal to its concrete instance. This
    // is a no-op when no struct is generic (every existing gate stays byte-identical).
    mono_structs_all(&fns, &mut structs);
    let nf = vec_len(&fns);
    // Type-check every fn against the registry.
    let mut bad = 0; let mut ci = 0;
    while ci < nf { let g = vec_get(&fns, ci); bad = if check_fn(&g, &structs, &fns) == 0 { 1 } else { bad }; ci = ci + 1; }
    if bad == 1 {
        let err = "; TYPE ERROR\n"; print_str(&err); 0 - 1
    } else {
        let ei = find_entry(&fns);
        let f = vec_get(&fns, ei);
        // Module preamble: an @.str global for every string literal across all fns
        // (globals must precede the function defines).
        let mut pre = string_new();
        let mut pj = 0;
        while pj < nf { let g = vec_get(&fns, pj); collect_strs_block(&g.body, &src, &mut pre); pj = pj + 1; }
        // v92: emit the Vec<i64> / growable-String runtime (libc declares + the
        // kdvec_*/kdstr_* defines) ONLY when the program actually uses them, so
        // every prior (no-Vec) program's preamble stays byte-for-byte identical.
        let wv = fns_use_rt(&fns, 1); let ws = fns_use_rt(&fns, 2);
        emit_runtime_decls(&mut pre, wv, ws);
        // Emit every NON-GENERIC fn. (A generic fn declaration emits NOTHING on its
        // own — only its monomorphized instances are emitted, below.)
        let mut out = string_new();
        let mut ej = 0;
        while ej < nf { let g = vec_get(&fns, ej); if g.gp == 0 { emit_fn(&g, &structs, &fns, &mut out); } else { let z = 0; } ej = ej + 1; }
        // v94: emit each requested generic-fn INSTANCE once (dedup by mangled name),
        // substituting the concrete tag for `T`. Mirrors the host's emittedInstances_.
        let reqs = mono_fns_all(&fns, &structs);
        let nr = vec_len(&reqs); let mut ri = 0;
        while ri < nr {
            let rq = vec_get(&reqs, ri);
            let gf = vec_get(&fns, rq.gi);
            emit_fn_inst(&gf, rq.tag, &rq.mname, &structs, &fns, &mut out);
            ri = ri + 1;
        }
        let mut args = vec_new();
        let np = vec_len(&f.params);
        let mut i = 0;
        while i < np {
            let idx = i + 2;
            let v = if arg_count() > idx { let a = arg_get(idx); match parse_int(&a) { Some(x) => x, None => 0 } } else { if i == 0 { 3 } else { 4 } };
            vec_push(&mut args, v);
            i = i + 1;
        }
        emit_main(&f, &args, &structs, &mut out);
        print_str(&pre); print_str(&out);
        0
    }
}
