#!/usr/bin/env bash
# kard — thin user-facing driver around the kardc binary.
#
# Subcommands:
#   kard build               # build the ./kard.toml project's entry point
#   kard build <file.kd>     # AOT-compile to ./<file> (drops .kd)
#   kard build <file.kd> -o <out>
#                            # AOT-compile to a custom path
#   kard run                 # run the ./kard.toml project's entry point (JIT)
#   kard run   <file.kd>     # JIT-run main()
#   kard test  <file.kd>     # discover + run `test_*() -> i64` fns (0 = pass)
#   kard bench <file.kd>     # discover + run `bench_*() -> i64` fns (times each)
#   kard fmt   <file.kd>     # print canonically-formatted source to stdout
#   kard fmt --check <file.kd>
#                            # exit non-zero if the file is not formatted (CI)
#   kard fmt -w <file.kd>    # rewrite the file in place
#   kard repl                # interactive REPL
#   kard help                # this message
#
# With no file, `kard build` / `kard run` read a `kard.toml` package manifest
# in the current directory (see the manifest section below): they compile the
# manifest's entry point and make local-path `[dependencies]` resolvable.
#
# Resolves kardc by checking, in order:
#   1. $KARDC env var, if set
#   2. ./compiler/kardc (Bazel default output)
#   3. ./build.local/kardc (Makefile.local output)
#   4. kardc on PATH
set -euo pipefail

find_kardc() {
    if [[ -n "${KARDC:-}" ]]; then
        echo "$KARDC"
        return
    fi
    local here
    here=$(cd "$(dirname "$0")" && pwd)
    for candidate in \
        "$here/compiler/kardc" \
        "$here/build.local/kardc" \
        "$here/bazel-bin/compiler/kardc"; do
        if [[ -x "$candidate" ]]; then
            echo "$candidate"
            return
        fi
    done
    if command -v kardc >/dev/null 2>&1; then
        command -v kardc
        return
    fi
    echo "kard: cannot find a kardc binary. Set \$KARDC or run from the repo." >&2
    exit 1
}

# Mirror of find_kardc for the formatter binary (kardfmt). Resolved lazily
# (only the `fmt` subcommand needs it) so other subcommands don't fail when
# kardfmt hasn't been built.
find_kardfmt() {
    if [[ -n "${KARDFMT:-}" ]]; then
        echo "$KARDFMT"
        return
    fi
    local here
    here=$(cd "$(dirname "$0")" && pwd)
    for candidate in \
        "$here/compiler/kardfmt" \
        "$here/build.local/kardfmt" \
        "$here/bazel-bin/compiler/kardfmt"; do
        if [[ -x "$candidate" ]]; then
            echo "$candidate"
            return
        fi
    done
    if command -v kardfmt >/dev/null 2>&1; then
        command -v kardfmt
        return
    fi
    echo "kard: cannot find a kardfmt binary. Set \$KARDFMT or run from the repo." >&2
    exit 1
}

KARDC_BIN=$(find_kardc)

# ---------------------------------------------------------------------------
# Phase 20b: package manifest (`kard.toml`) + local-path dependency resolution.
#
# A project may carry a `kard.toml` at its root:
#
#   [package]
#   name = "myapp"
#   version = "0.1.0"
#   entry = "src/main.kd"        # optional; defaults to src/main.kd
#
#   [dependencies]
#   mathlib = { path = "../mathlib" }   # local-path dep (inline-table form)
#   strutil = "../strutil"               # local-path dep (bare-string form)
#
# When `kard build` / `kard run` is invoked with NO explicit file, we read the
# manifest in the current directory, compile its entry point, and make each
# local-path dependency resolvable: the dep's library file is staged as a
# `<name>.kd` sibling of the entry so the existing `mod <name>;` flat-merge
# (kardc's intra-project resolver) finds it. We stage via symlink (falling back
# to a copy) and remove exactly what we staged on exit, so the source tree is
# left untouched.
#
# A dependency's library file is located by trying, under its path P:
#   P/<name>.kd, P/src/lib.kd, P/lib.kd, P/src/<name>.kd  — or P itself if it is
# a `.kd` file. The first that exists wins.
#
# DEFERRED (documented, not stubbed): resolving THIRD-PARTY deps via the Bazel
# module registry. Bazel can't run in this build environment, so a real
# registry integration isn't verifiable here and is intentionally left as
# future work. The manifest + local-path resolution above is fully implemented
# and tested (tests/smoke_test_manifest.sh). See README "Roadmap v3 / Phase 20".
# ---------------------------------------------------------------------------

MANIFEST_NAME="kard.toml"

# Trim leading/trailing whitespace from $1 (POSIX, no `echo -n` portability
# traps). Uses parameter expansion so it works on bash 3.2 (macOS).
trim() {
    local s="$1"
    # strip leading whitespace
    s="${s#"${s%%[![:space:]]*}"}"
    # strip trailing whitespace
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

# Read a scalar key from the [package] section of a manifest file.
# Usage: manifest_package_value <manifest> <key>  -> prints value or "".
manifest_package_value() {
    local manifest="$1" want="$2" section="" line key val
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"                 # strip comments
        line="$(trim "$line")"
        [[ -z "$line" ]] && continue
        if [[ "$line" == "["*"]" ]]; then
            section="$(trim "${line#[}")"; section="$(trim "${section%]}")"
            continue
        fi
        [[ "$section" != "package" ]] && continue
        case "$line" in
            *=*) ;;
            *) continue ;;
        esac
        key="$(trim "${line%%=*}")"
        [[ "$key" != "$want" ]] && continue
        val="$(trim "${line#*=}")"
        # strip surrounding quotes (single or double)
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        printf '%s' "$val"
        return 0
    done < "$manifest"
    printf ''
}

# Emit `name<TAB>path` for each [dependencies] entry. Accepts both the
# inline-table form `name = { path = "..." }` and the bare-string form
# `name = "..."`.
manifest_dependencies() {
    local manifest="$1" section="" line key val path
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="$(trim "$line")"
        [[ -z "$line" ]] && continue
        if [[ "$line" == "["*"]" ]]; then
            section="$(trim "${line#[}")"; section="$(trim "${section%]}")"
            continue
        fi
        [[ "$section" != "dependencies" ]] && continue
        case "$line" in
            *=*) ;;
            *) continue ;;
        esac
        key="$(trim "${line%%=*}")"
        val="$(trim "${line#*=}")"
        if [[ "$val" == "{"*"}" ]]; then
            # inline table: pull out the path = "..." field
            local inner="${val#\{}"; inner="${inner%\}}"
            # split on commas, find path=
            path=""
            local IFS_SAVE="$IFS"
            IFS=','
            local part
            for part in $inner; do
                part="$(trim "$part")"
                case "$part" in
                    path*=*)
                        path="$(trim "${part#*=}")"
                        path="${path%\"}"; path="${path#\"}"
                        path="${path%\'}"; path="${path#\'}"
                        ;;
                esac
            done
            IFS="$IFS_SAVE"
        else
            path="${val%\"}"; path="${path#\"}"
            path="${path%\'}"; path="${path#\'}"
        fi
        [[ -z "$path" ]] && continue
        printf '%s\t%s\n' "$key" "$path"
    done < "$manifest"
}

# Canonicalize a path to absolute. For an existing directory, `cd && pwd`.
# For a file, canonicalize its directory then re-append the basename. Falls
# back to prefixing $PWD for non-existent paths. We return ABSOLUTE paths so a
# staged symlink's target is valid regardless of the symlink's own location
# (a relative target would be resolved against the link dir, not the CWD).
abspath() {
    local p="$1"
    if [[ -d "$p" ]]; then
        ( cd "$p" && pwd )
    elif [[ -f "$p" ]]; then
        local d b
        d="$(cd "$(dirname "$p")" && pwd)"
        b="$(basename "$p")"
        printf '%s/%s' "$d" "$b"
    else
        case "$p" in
            /*) printf '%s' "$p" ;;
            *)  printf '%s/%s' "$PWD" "$p" ;;
        esac
    fi
}

# Locate a dependency's library .kd file given its declared path. The path is
# resolved relative to $3 (the manifest's directory). Prints the resolved
# ABSOLUTE file path on success, nothing on failure.
resolve_dep_file() {
    local name="$1" path="$2" base="$3" p
    # Make path absolute relative to the manifest dir.
    case "$path" in
        /*) p="$path" ;;
        *)  p="$base/$path" ;;
    esac
    if [[ -f "$p" && "$p" == *.kd ]]; then
        abspath "$p"; return 0
    fi
    local candidate
    for candidate in \
        "$p/$name.kd" \
        "$p/src/lib.kd" \
        "$p/lib.kd" \
        "$p/src/$name.kd"; do
        if [[ -f "$candidate" ]]; then
            abspath "$candidate"; return 0
        fi
    done
    printf ''
}

# Globals populated by stage_dependencies / cleaned by unstage_dependencies.
STAGED_LINKS=()

# Stage each local-path dep as a `<name>.kd` sibling of the entry file so
# `mod <name>;` resolves it. Tracks created files in STAGED_LINKS. Errors
# (missing dep file, name collision with a real source file) are fatal.
stage_dependencies() {
    local manifest="$1" entry_dir="$2" base="$3"
    local line name path depfile target
    # Read deps into an array first (avoids a subshell so STAGED_LINKS persists).
    local deps
    deps="$(manifest_dependencies "$manifest")"
    [[ -z "$deps" ]] && return 0
    while IFS=$'\t' read -r name path; do
        [[ -z "$name" ]] && continue
        depfile="$(resolve_dep_file "$name" "$path" "$base")"
        if [[ -z "$depfile" ]]; then
            echo "kard: dependency '$name' — no library .kd found at '$path'" >&2
            unstage_dependencies
            exit 1
        fi
        target="$entry_dir/$name.kd"
        # If a real (non-staged) file already sits there, don't clobber it.
        if [[ -e "$target" && ! -L "$target" ]]; then
            # Already a sibling source with this name — assume it's the dep and
            # leave it (the flat-merge will pick it up). Skip staging.
            continue
        fi
        # Remove any stale symlink from a previous run, then stage afresh.
        [[ -L "$target" ]] && rm -f "$target"
        if ln -s "$depfile" "$target" 2>/dev/null; then
            :
        else
            cp "$depfile" "$target"   # filesystems without symlink support
        fi
        STAGED_LINKS+=("$target")
    done <<< "$deps"
}

# Remove every file staged by stage_dependencies.
unstage_dependencies() {
    local f
    for f in "${STAGED_LINKS[@]:-}"; do
        [[ -n "$f" ]] && rm -f "$f"
    done
    STAGED_LINKS=()
}

# True if any argument names a `.kd` source file (a positional input). Used to
# decide manifest mode: `build`/`run` with NO `.kd` argument fall back to the
# ./kard.toml entry point; flags like `-O0` / `-g` alone don't suppress that.
has_kd_file_arg() {
    local a
    for a in "$@"; do
        case "$a" in
            *.kd) return 0 ;;
        esac
    done
    return 1
}

# Run a manifest-driven build/run: prepare the project, stage local-path deps,
# invoke kardc with $@ (a leading "-o <out>" is honored for builds), then
# unstage and propagate the exit code. $1 selects mode: "build" or "run".
run_manifest() {
    local mode="$1"; shift
    prepare_project "."
    trap unstage_dependencies EXIT
    stage_dependencies "$PROJ_MANIFEST" "$PROJ_ENTRY_DIR" "$PROJ_BASE"
    local rc
    set +e
    if [[ "$mode" == "build" ]]; then
        local out=""
        if [[ $# -ge 2 && "$1" == "-o" ]]; then out=$2; shift 2; fi
        [[ -z "$out" ]] && out="$PROJ_NAME"
        "$KARDC_BIN" -o "$out" "$PROJ_ENTRY" "$@"
    else
        "$KARDC_BIN" "$PROJ_ENTRY" "$@"
    fi
    rc=$?
    set -e
    unstage_dependencies; trap - EXIT
    exit $rc
}

# Resolve a project (READ-ONLY): set the globals PROJ_ENTRY (entry .kd file),
# PROJ_ENTRY_DIR (its directory), PROJ_NAME (package name), and PROJ_MANIFEST
# for the manifest in directory $1, or fail. Staging is done separately (by the
# caller) so the staged-link bookkeeping survives in the parent shell.
PROJ_ENTRY=""
PROJ_ENTRY_DIR=""
PROJ_NAME=""
PROJ_MANIFEST=""
PROJ_BASE=""
prepare_project() {
    local dir="$1"
    local manifest="$dir/$MANIFEST_NAME"
    if [[ ! -f "$manifest" ]]; then
        echo "kard: no $MANIFEST_NAME found in '$dir' (and no file given)" >&2
        echo "kard: run inside a project dir or pass a .kd file explicitly." >&2
        exit 1
    fi
    local pkg_name entry
    pkg_name="$(manifest_package_value "$manifest" name)"
    if [[ -z "$pkg_name" ]]; then
        echo "kard: $MANIFEST_NAME is missing [package] name" >&2
        exit 1
    fi
    entry="$(manifest_package_value "$manifest" entry)"
    [[ -z "$entry" ]] && entry="src/main.kd"
    local entry_file
    case "$entry" in
        /*) entry_file="$entry" ;;
        *)  entry_file="$dir/$entry" ;;
    esac
    if [[ ! -f "$entry_file" ]]; then
        echo "kard: entry point '$entry' not found (looked at '$entry_file')" >&2
        exit 1
    fi
    local entry_dir
    entry_dir="$(cd "$(dirname "$entry_file")" && pwd)"
    PROJ_ENTRY="$entry_dir/$(basename "$entry_file")"
    PROJ_ENTRY_DIR="$entry_dir"
    PROJ_NAME="$pkg_name"
    PROJ_MANIFEST="$manifest"
    PROJ_BASE="$dir"
}

usage() {
    sed -n '2,22p' "$0" | sed 's/^# *//'
}

cmd=${1:-help}
shift || true

case "$cmd" in
    build)
        # Manifest mode: `kard build` with no .kd file (or only `-o <out>`)
        # reads ./kard.toml, compiles its entry point, and stages local-path
        # deps first. An optional `-o <out>` still selects the output path.
        if ! has_kd_file_arg "$@"; then
            run_manifest build "$@"
        fi
        file=$1; shift
        if [[ $# -ge 2 && "$1" == "-o" ]]; then
            out=$2; shift 2
        else
            out=$(basename "$file" .kd)
        fi
        exec "$KARDC_BIN" -o "$out" "$file" "$@"
        ;;
    run)
        # Manifest mode: `kard run` with no .kd file reads ./kard.toml and
        # JIT-runs its entry point (local-path deps staged first).
        if ! has_kd_file_arg "$@"; then
            run_manifest run "$@"
        fi
        exec "$KARDC_BIN" "$@"
        ;;
    test)
        if [[ $# -eq 0 ]]; then
            echo "kard test: missing file" >&2
            exit 2
        fi
        # Pass all args through so `-O0` etc. reach kardc alongside --test.
        exec "$KARDC_BIN" --test "$@"
        ;;
    bench)
        if [[ $# -eq 0 ]]; then
            echo "kard bench: missing file" >&2
            exit 2
        fi
        # v109: discover + run bench_* fns; pass args through (--filter, -O*, …).
        exec "$KARDC_BIN" --bench "$@"
        ;;
    fmt)
        if [[ $# -eq 0 ]]; then
            echo "kard fmt: missing file" >&2
            exit 2
        fi
        KARDFMT_BIN=$(find_kardfmt)
        # Pass all args through verbatim so `--check` / `-w` reach kardfmt.
        exec "$KARDFMT_BIN" "$@"
        ;;
    repl)
        exec "$KARDC_BIN"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "kard: unknown subcommand `$cmd`" >&2
        usage >&2
        exit 2
        ;;
esac
